{
  "name": "@asab/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx scripts/migrate.ts migrate dev",
    "prisma:deploy": "tsx scripts/migrate.ts migrate deploy",
    "prisma:status": "tsx scripts/migrate.ts migrate status",
    "prisma:studio": "tsx scripts/migrate.ts studio",
    "verify:rls": "tsx scripts/verify-rls.ts",
    "verify:tenant": "tsx scripts/verify-tenant.ts",
    "verify:auth": "tsx scripts/verify-auth.ts",
    "verify:storage": "tsx scripts/verify-storage.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@asab/shared": "*",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^5.18.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "^5.10.0",
    "openai": "^4.56.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.15",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
