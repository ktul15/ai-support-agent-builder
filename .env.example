# Copy to .env and fill in real values:  cp .env.example .env
# Validated by api/src/config.ts at boot — missing/invalid required vars abort startup.
# Never commit .env. Secrets are server-side only; never expose to clients.

# --- Core runtime (optional; defaults shown) ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Infrastructure (REQUIRED) ---
# What the APP connects with: the RESTRICTED `asab_app` role, so Row-Level
# Security applies to runtime queries. The role is provisioned out-of-band
# (db/init/002-app-role.sh locally; manually in prod) — NOT by a migration — so
# no password is committed. The password here must match $ASAB_APP_PASSWORD.
# Postgres uses host port 5433 (compose default) to avoid clashing with a native
# Postgres on 5432.
DATABASE_URL=postgres://asab_app:asab_app_dev_pw@localhost:5433/asab
# Owner role for MIGRATIONS only (Prisma directUrl). DDL needs ownership/superuser;
# never used for runtime queries (it would bypass RLS).
DIRECT_DATABASE_URL=postgres://postgres:postgres@localhost:5433/asab
REDIS_URL=redis://localhost:6379

# --- Local Docker (optional; consumed by docker-compose.yml, NOT the app) ---
# Override only if the default ports clash with something already running locally.
# IMPORTANT: if you change any of these, update DATABASE_URL / REDIS_URL above to match.
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=asab
# POSTGRES_PORT=5433
# REDIS_PORT=6379
# Password for the restricted asab_app role (db/init/002-app-role.sh). Must match
# the password in DATABASE_URL above. Dev default; set a real secret in prod.
# ASAB_APP_PASSWORD=asab_app_dev_pw

# --- Auth (REQUIRED) ---
# Min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# --- AI providers (REQUIRED; server-side only) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxx
# Optional — reranker (stretch, issue #46)
# COHERE_API_KEY=

# --- Model selection (optional; defaults shown) ---
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=claude-haiku-4-5

# --- Object storage / R2 / S3 (optional until upload pipeline, issue #11) ---
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=asab-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
